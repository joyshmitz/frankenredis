  "cases": [
    {
      "name": "eval_return_integer",
      "now_ms": 0,
      "argv": [
        "EVAL",
        "return 1",
        "0"
      ],
      "expect": {
        "kind": "integer",
        "value": 1
      }
    },
    {
      "name": "eval_return_string",
      "now_ms": 0,
      "argv": [
        "EVAL",
        "return 'hello'",
        "0"
      ],
      "expect": {
        "kind": "bulk",
        "value": "hello"
      }
    },
    {
      "name": "eval_return_nil",
      "now_ms": 0,
      "argv": [
        "EVAL",
        "return nil",
        "0"
      ],
