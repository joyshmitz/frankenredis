    {
      "name": "config_get_prefix_pattern_maxmemory",
      "now_ms": 0,
      "argv": ["CONFIG", "GET", "maxmemory*"],
      "expect": {
        "kind": "array",
        "value": [
          { "kind": "bulk", "value": "maxmemory" },
