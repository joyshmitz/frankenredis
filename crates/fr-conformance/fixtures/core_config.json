          { "kind": "bulk", "value": "maxmemory-policy" },
          { "kind": "bulk", "value": "noeviction" },
          { "kind": "bulk", "value": "maxmemory-samples" },
          { "kind": "bulk", "value": "5" },
          { "kind": "bulk", "value": "maxmemory-eviction-tenacity" },
          { "kind": "bulk", "value": "10" }
        ]
      }
    },
    {
      "name": "config_get_prefix_pattern_cluster",
