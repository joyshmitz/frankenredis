    },
    {
      "name": "config_set_unknown_param_error",
      "now_ms": 0,
      "argv": ["CONFIG", "SET", "totally-fake-param", "value"],
      "expect": { "kind": "error", "value": "ERR Unsupported CONFIG parameter 'totally-fake-param'" }
    },
    {
      "name": "config_set_maxmemory_negative_error",
      "now_ms": 0,
      "argv": ["CONFIG", "SET", "maxmemory", "-1"],
      "expect": { "kind": "error", "value": "ERR Invalid argument '?' for CONFIG SET 'maxmemory'" }
    },
    {
      "name": "config_set_acllog_negative_error",
      "now_ms": 0,
      "argv": ["CONFIG", "SET", "acllog-max-len", "-5"],
      "expect": { "kind": "error", "value": "ERR CONFIG SET acllog-max-len must be a non-negative integer" }
    },
    {
      "name": "config_set_maxmemory_non_integer_error",
      "now_ms": 0,
      "argv": ["CONFIG", "SET", "maxmemory", "abc"],
      "expect": { "kind": "error", "value": "ERR value is not an integer or out of range" }
    },
