{
  "suite": "core_config",
  "cases": [
    {
      "name": "config_get_exact_maxmemory",
      "now_ms": 0,
      "argv": ["CONFIG", "GET", "maxmemory"],
      "expect": {
        "kind": "array",
        "value": [
          { "kind": "bulk", "value": "maxmemory" },
          { "kind": "bulk", "value": "0" }
        ]
      }
    },
    {
      "name": "config_get_exact_bind",
      "now_ms": 0,
      "argv": ["CONFIG", "GET", "bind"],
      "expect": {
        "kind": "array",
        "value": [
          { "kind": "bulk", "value": "bind" },
          { "kind": "bulk", "value": "127.0.0.1" }
        ]
      }
    },
    {
