          { "kind": "bulk", "value": "lazyfree-lazy-user-flush" },
          { "kind": "bulk", "value": "no" }
        ]
      }
    },
    {
      "name": "config_set_maxmemory",
      "now_ms": 0,
      "argv": ["CONFIG", "SET", "maxmemory", "1048576"],
