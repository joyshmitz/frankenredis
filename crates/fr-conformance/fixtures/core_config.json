    },
    {
      "name": "config_wrong_arity_no_subcommand",
      "now_ms": 0,
      "argv": ["CONFIG"],
      "expect": { "kind": "error", "value": "ERR wrong number of arguments for 'CONFIG' command" }
    },
    {
      "name": "config_get_wrong_arity",
      "now_ms": 0,
      "argv": ["CONFIG", "GET"],
      "expect": { "kind": "error", "value": "ERR wrong number of arguments for 'CONFIG' command" }
    },
    {
      "name": "config_set_wrong_arity_odd",
      "now_ms": 0,
      "argv": ["CONFIG", "SET", "maxmemory"],
      "expect": { "kind": "error", "value": "ERR wrong number of arguments for 'CONFIG' command" }
    },
    {
      "name": "config_resetstat_wrong_arity",
      "now_ms": 0,
      "argv": ["CONFIG", "RESETSTAT", "extra"],
      "expect": { "kind": "error", "value": "ERR wrong number of arguments for 'CONFIG' command" }
    },
    {
      "name": "config_unknown_subcommand",
      "now_ms": 0,
      "argv": ["CONFIG", "NOSUCH"],
      "expect": { "kind": "error", "value": "ERR Unknown subcommand or wrong number of arguments for CONFIG NOSUCH" }
    },
    {
      "name": "config_get_case_insensitive",
      "now_ms": 0,
      "argv": ["CONFIG", "get", "MAXMEMORY"],
