    {
      "name": "config_get_io_threads",
      "now_ms": 0,
      "argv": ["CONFIG", "GET", "io-threads"],
      "expect": {
        "kind": "array",
        "value": [
          { "kind": "bulk", "value": "io-threads" },
          { "kind": "bulk", "value": "1" }
        ]
