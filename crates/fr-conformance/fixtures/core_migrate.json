{
  "suite": "core_migrate",
  "cases": [
    {
      "name": "migrate_wrong_arity_no_args",
      "now_ms": 0,
      "argv": ["MIGRATE"],
      "expect": {
        "kind": "error",
        "value": "ERR wrong number of arguments for 'migrate' command"
      }
    },
    {
      "name": "migrate_wrong_arity_too_few",
      "now_ms": 1,
      "argv": ["MIGRATE", "127.0.0.1", "6379", "key"],
      "expect": {
        "kind": "error",
        "value": "ERR wrong number of arguments for 'migrate' command"
      }
    },
    {
      "name": "migrate_wrong_arity_five_args",
      "now_ms": 2,
      "argv": ["MIGRATE", "127.0.0.1", "6379", "key", "0"],
      "expect": {
        "kind": "error",
        "value": "ERR wrong number of arguments for 'migrate' command"
      }
    },
    {
      "name": "migrate_invalid_port",
      "now_ms": 3,
      "argv": ["MIGRATE", "127.0.0.1", "notaport", "key", "0", "1000"],
      "expect": {
        "kind": "error",
        "value": "ERR value is not an integer or out of range"
      }
    },
    {
      "name": "migrate_invalid_db",
      "now_ms": 4,
      "argv": ["MIGRATE", "127.0.0.1", "6379", "key", "notadb", "1000"],
      "expect": {
        "kind": "error",
        "value": "ERR value is not an integer or out of range"
      }
    },
    {
      "name": "migrate_invalid_timeout",
      "now_ms": 5,
      "argv": ["MIGRATE", "127.0.0.1", "6379", "key", "0", "notatimeout"],
      "expect": {
        "kind": "error",
        "value": "ERR value is not an integer or out of range"
      }
    },
    {
      "name": "migrate_unknown_option_syntax_error",
      "now_ms": 6,
      "argv": ["MIGRATE", "127.0.0.1", "6379", "key", "0", "1000", "BOGUS"],
      "expect": {
        "kind": "error",
        "value": "ERR syntax error"
      }
    },
    {
      "name": "migrate_auth_missing_password_syntax_error",
      "now_ms": 7,
      "argv": ["MIGRATE", "127.0.0.1", "6379", "key", "0", "1000", "AUTH"],
      "expect": {
        "kind": "error",
        "value": "ERR syntax error"
      }
    },
    {
      "name": "migrate_auth2_missing_args_syntax_error",
      "now_ms": 8,
      "argv": ["MIGRATE", "127.0.0.1", "6379", "key", "0", "1000", "AUTH2", "user"],
      "expect": {
        "kind": "error",
        "value": "ERR syntax error"
      }
    },
    {
      "name": "migrate_keys_with_nonempty_key_error",
      "now_ms": 9,
      "argv": ["MIGRATE", "127.0.0.1", "6379", "mykey", "0", "1000", "KEYS", "k1", "k2"],
      "expect": {
        "kind": "error",
        "value": "ERR When using MIGRATE KEYS option, the key argument must be set to the empty string"
      }
    },
    {
      "name": "migrate_nokey_nonexistent_key",
      "now_ms": 10,
      "argv": ["MIGRATE", "127.0.0.1", "6379", "nonexistent", "0", "1000"],
      "expect": {
        "kind": "simple",
        "value": "NOKEY"
      }
    },
    {
      "name": "migrate_nokey_empty_keys_list",
      "now_ms": 11,
      "argv": ["MIGRATE", "127.0.0.1", "6379", "", "0", "1000", "KEYS"],
      "expect": {
        "kind": "simple",
        "value": "NOKEY"
      }
    },
    {
      "name": "migrate_port_negative",
      "now_ms": 12,
      "argv": ["MIGRATE", "127.0.0.1", "-1", "key", "0", "1000"],
      "expect": {
        "kind": "error",
        "value": "ERR value is not an integer or out of range"
      }
    },
    {
      "name": "migrate_port_float",
      "now_ms": 13,
      "argv": ["MIGRATE", "127.0.0.1", "6379.5", "key", "0", "1000"],
      "expect": {
        "kind": "error",
        "value": "ERR value is not an integer or out of range"
      }
    },
    {
      "name": "migrate_port_empty",
      "now_ms": 14,
      "argv": ["MIGRATE", "127.0.0.1", "", "key", "0", "1000"],
      "expect": {
        "kind": "error",
        "value": "ERR value is not an integer or out of range"
      }
    },
    {
      "name": "migrate_db_float",
      "now_ms": 15,
      "argv": ["MIGRATE", "127.0.0.1", "6379", "key", "0.5", "1000"],
      "expect": {
        "kind": "error",
        "value": "ERR value is not an integer or out of range"
      }
    },
    {
      "name": "migrate_db_empty",
      "now_ms": 16,
      "argv": ["MIGRATE", "127.0.0.1", "6379", "key", "", "1000"],
      "expect": {
        "kind": "error",
        "value": "ERR value is not an integer or out of range"
      }
    },
    {
      "name": "migrate_timeout_float",
      "now_ms": 17,
      "argv": ["MIGRATE", "127.0.0.1", "6379", "key", "0", "1000.5"],
      "expect": {
        "kind": "error",
        "value": "ERR value is not an integer or out of range"
      }
    },
    {
      "name": "migrate_timeout_empty",
      "now_ms": 18,
      "argv": ["MIGRATE", "127.0.0.1", "6379", "key", "0", ""],
      "expect": {
        "kind": "error",
        "value": "ERR value is not an integer or out of range"
      }
    },
    {
      "name": "migrate_port_out_of_range",
      "now_ms": 19,
      "argv": ["MIGRATE", "127.0.0.1", "99999", "key", "0", "1000"],
      "expect": {
        "kind": "error",
        "value": "ERR value is not an integer or out of range"
      }
    },
    {
      "name": "migrate_port_leading_plus",
      "now_ms": 20,
      "argv": ["MIGRATE", "127.0.0.1", "+6379", "key", "0", "1000"],
      "expect": {
        "kind": "error",
        "value": "ERR value is not an integer or out of range"
      }
    },
    {
      "name": "migrate_port_leading_zero",
      "now_ms": 21,
      "argv": ["MIGRATE", "127.0.0.1", "06379", "key", "0", "1000"],
      "expect": {
        "kind": "error",
        "value": "ERR value is not an integer or out of range"
      }
    },
    {
      "name": "migrate_db_negative",
      "now_ms": 22,
      "argv": ["MIGRATE", "127.0.0.1", "6379", "key", "-1", "1000"],
      "expect": {
        "kind": "simple",
        "value": "NOKEY"
      }
    },
    {
      "name": "migrate_timeout_negative",
      "now_ms": 23,
      "argv": ["MIGRATE", "127.0.0.1", "6379", "key", "0", "-1"],
      "expect": {
        "kind": "simple",
        "value": "NOKEY"
      }
    },
    {
      "name": "migrate_copy_option_nokey",
      "now_ms": 24,
      "argv": ["MIGRATE", "127.0.0.1", "6379", "nokey_copy", "0", "1000", "COPY"],
      "expect": {
        "kind": "simple",
        "value": "NOKEY"
      }
    },
    {
      "name": "migrate_replace_option_nokey",
      "now_ms": 25,
      "argv": ["MIGRATE", "127.0.0.1", "6379", "nokey_replace", "0", "1000", "REPLACE"],
      "expect": {
        "kind": "simple",
        "value": "NOKEY"
      }
    },
    {
      "name": "migrate_copy_replace_combined_nokey",
      "now_ms": 26,
      "argv": ["MIGRATE", "127.0.0.1", "6379", "nokey_both", "0", "1000", "COPY", "REPLACE"],
      "expect": {
        "kind": "simple",
        "value": "NOKEY"
      }
    },
    {
      "name": "migrate_auth_with_password_nokey",
      "now_ms": 27,
      "argv": ["MIGRATE", "127.0.0.1", "6379", "nokey_auth", "0", "1000", "AUTH", "secret"],
      "expect": {
        "kind": "simple",
        "value": "NOKEY"
      }
    },
    {
      "name": "migrate_auth2_with_user_pass_nokey",
      "now_ms": 28,
      "argv": ["MIGRATE", "127.0.0.1", "6379", "nokey_auth2", "0", "1000", "AUTH2", "user", "pass"],
      "expect": {
        "kind": "simple",
        "value": "NOKEY"
      }
    },
    {
      "name": "migrate_keys_option_with_multiple_keys_nokey",
      "now_ms": 29,
      "argv": ["MIGRATE", "127.0.0.1", "6379", "", "0", "1000", "KEYS", "k1", "k2", "k3"],
      "expect": {
        "kind": "simple",
        "value": "NOKEY"
      }
    },
    {
      "name": "migrate_all_options_combined_nokey",
      "now_ms": 30,
      "argv": ["MIGRATE", "127.0.0.1", "6379", "", "0", "1000", "COPY", "REPLACE", "AUTH", "pw", "KEYS", "a", "b"],
      "expect": {
        "kind": "simple",
        "value": "NOKEY"
      }
    },
    {
      "name": "migrate_auth2_syntax_error_only_user",
      "now_ms": 31,
      "argv": ["MIGRATE", "127.0.0.1", "6379", "key", "0", "1000", "AUTH2"],
      "expect": {
        "kind": "error",
        "value": "ERR syntax error"
      }
    },
    {
      "name": "migrate_keys_duplicate_option",
      "now_ms": 32,
      "argv": ["MIGRATE", "127.0.0.1", "6379", "", "0", "1000", "KEYS", "k1", "KEYS", "k2"],
      "expect": {
        "kind": "simple",
        "value": "NOKEY"
      }
    },
    {
      "name": "migrate_port_zero",
      "now_ms": 33,
      "argv": ["MIGRATE", "127.0.0.1", "0", "key", "0", "1000"],
      "expect": {
        "kind": "simple",
        "value": "NOKEY"
      }
    },
    {
      "name": "migrate_port_65535_max_valid",
      "now_ms": 34,
      "argv": ["MIGRATE", "127.0.0.1", "65535", "key", "0", "1000"],
      "expect": {
        "kind": "simple",
        "value": "NOKEY"
      }
    },
    {
      "name": "migrate_port_65536_out_of_range",
      "now_ms": 35,
      "argv": ["MIGRATE", "127.0.0.1", "65536", "key", "0", "1000"],
      "expect": {
        "kind": "error",
        "value": "ERR value is not an integer or out of range"
      }
    },
    {
      "name": "migrate_db_very_large",
      "now_ms": 36,
      "argv": ["MIGRATE", "127.0.0.1", "6379", "key", "999999999999", "1000"],
      "expect": {
        "kind": "simple",
        "value": "NOKEY"
      }
    },
    {
      "name": "migrate_timeout_zero",
      "now_ms": 37,
      "argv": ["MIGRATE", "127.0.0.1", "6379", "key", "0", "0"],
      "expect": {
        "kind": "simple",
        "value": "NOKEY"
      }
    },
    {
      "name": "migrate_timeout_very_large",
      "now_ms": 38,
      "argv": ["MIGRATE", "127.0.0.1", "6379", "key", "0", "9999999999999"],
      "expect": {
        "kind": "simple",
        "value": "NOKEY"
      }
    },
    {
      "name": "migrate_empty_host",
      "now_ms": 39,
      "argv": ["MIGRATE", "", "6379", "key", "0", "1000"],
      "expect": {
        "kind": "simple",
        "value": "NOKEY"
      }
    },
    {
      "name": "migrate_auth_empty_password",
      "now_ms": 40,
      "argv": ["MIGRATE", "127.0.0.1", "6379", "nokey", "0", "1000", "AUTH", ""],
      "expect": {
        "kind": "simple",
        "value": "NOKEY"
      }
    },
    {
      "name": "migrate_auth2_empty_credentials",
      "now_ms": 41,
      "argv": ["MIGRATE", "127.0.0.1", "6379", "nokey", "0", "1000", "AUTH2", "", ""],
      "expect": {
        "kind": "simple",
        "value": "NOKEY"
      }
    },
    {
      "name": "migrate_options_case_insensitive_copy",
      "now_ms": 42,
      "argv": ["MIGRATE", "127.0.0.1", "6379", "nokey", "0", "1000", "copy"],
      "expect": {
        "kind": "simple",
        "value": "NOKEY"
      }
    },
    {
      "name": "migrate_options_case_insensitive_replace",
      "now_ms": 43,
      "argv": ["MIGRATE", "127.0.0.1", "6379", "nokey", "0", "1000", "replace"],
      "expect": {
        "kind": "simple",
        "value": "NOKEY"
      }
    },
    {
      "name": "migrate_options_case_insensitive_auth",
      "now_ms": 44,
      "argv": ["MIGRATE", "127.0.0.1", "6379", "nokey", "0", "1000", "auth", "secret"],
      "expect": {
        "kind": "simple",
        "value": "NOKEY"
      }
    },
    {
      "name": "migrate_options_case_insensitive_keys",
      "now_ms": 45,
      "argv": ["MIGRATE", "127.0.0.1", "6379", "", "0", "1000", "keys", "k1"],
      "expect": {
        "kind": "simple",
        "value": "NOKEY"
      }
    },
    {
      "name": "migrate_all_options_different_order",
      "now_ms": 46,
      "argv": ["MIGRATE", "127.0.0.1", "6379", "", "0", "1000", "AUTH", "pw", "REPLACE", "COPY", "KEYS", "a"],
      "expect": {
        "kind": "simple",
        "value": "NOKEY"
      }
    },
    {
      "name": "migrate_auth2_then_replace_copy",
      "now_ms": 47,
      "argv": ["MIGRATE", "127.0.0.1", "6379", "", "0", "1000", "AUTH2", "user", "pass", "REPLACE", "COPY", "KEYS", "k"],
      "expect": {
        "kind": "simple",
        "value": "NOKEY"
      }
    },
    {
      "name": "migrate_port_whitespace_invalid",
      "now_ms": 48,
      "argv": ["MIGRATE", "127.0.0.1", " 6379", "key", "0", "1000"],
      "expect": {
        "kind": "error",
        "value": "ERR value is not an integer or out of range"
      }
    },
    {
      "name": "migrate_db_whitespace_invalid",
      "now_ms": 49,
      "argv": ["MIGRATE", "127.0.0.1", "6379", "key", " 0", "1000"],
      "expect": {
        "kind": "error",
        "value": "ERR value is not an integer or out of range"
      }
    },
    {
      "name": "migrate_timeout_whitespace_invalid",
      "now_ms": 50,
      "argv": ["MIGRATE", "127.0.0.1", "6379", "key", "0", " 1000"],
      "expect": {
        "kind": "error",
        "value": "ERR value is not an integer or out of range"
      }
    }
  ]
}
