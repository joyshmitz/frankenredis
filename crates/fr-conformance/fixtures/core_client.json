{
  "suite": "core_client",
  "cases": [
    {
      "name": "client_getname_initially_nil",
      "now_ms": 1,
      "argv": ["CLIENT", "GETNAME"],
      "expect": { "kind": "bulk", "value": null }
    },
    {
      "name": "client_setname_ok",
      "now_ms": 2,
      "argv": ["CLIENT", "SETNAME", "myconn"],
      "expect": { "kind": "simple", "value": "OK" }
    },
    {
      "name": "client_getname_after_setname",
      "now_ms": 3,
      "argv": ["CLIENT", "GETNAME"],
      "expect": { "kind": "bulk", "value": "myconn" }
    },
    {
      "name": "client_setname_overwrite",
      "now_ms": 4,
      "argv": ["CLIENT", "SETNAME", "newname"],
      "expect": { "kind": "simple", "value": "OK" }
    },
    {
      "name": "client_getname_after_overwrite",
      "now_ms": 5,
      "argv": ["CLIENT", "GETNAME"],
      "expect": { "kind": "bulk", "value": "newname" }
    },
    {
      "name": "client_setname_clear_with_empty",
      "now_ms": 6,
      "argv": ["CLIENT", "SETNAME", ""],
      "expect": { "kind": "simple", "value": "OK" }
    },
    {
      "name": "client_getname_after_clear",
      "now_ms": 7,
      "argv": ["CLIENT", "GETNAME"],
      "expect": { "kind": "bulk", "value": null }
    },
    {
      "name": "client_setname_spaces_rejected",
      "now_ms": 8,
      "argv": ["CLIENT", "SETNAME", "my conn"],
      "expect": {
        "kind": "error",
        "value": "ERR Client names cannot contain spaces, newlines or special characters."
      }
    },
    {
      "name": "client_setname_wrong_arity",
      "now_ms": 9,
      "argv": ["CLIENT", "SETNAME"],
      "expect": {
        "kind": "error",
        "value": "ERR wrong number of arguments for 'CLIENT' command"
      }
    },
    {
      "name": "client_no_evict_on",
      "now_ms": 10,
      "argv": ["CLIENT", "NO-EVICT", "ON"],
      "expect": { "kind": "simple", "value": "OK" }
    },
    {
      "name": "client_no_evict_off",
      "now_ms": 11,
      "argv": ["CLIENT", "NO-EVICT", "OFF"],
      "expect": { "kind": "simple", "value": "OK" }
    },
    {
      "name": "client_no_evict_invalid_arg",
      "now_ms": 12,
      "argv": ["CLIENT", "NO-EVICT", "MAYBE"],
      "expect": {
        "kind": "error",
        "value": "ERR argument must be 'on' or 'off'"
      }
    },
    {
      "name": "client_no_touch_on",
      "now_ms": 13,
      "argv": ["CLIENT", "NO-TOUCH", "ON"],
      "expect": { "kind": "simple", "value": "OK" }
    },
    {
      "name": "client_no_touch_off",
      "now_ms": 14,
      "argv": ["CLIENT", "NO-TOUCH", "OFF"],
      "expect": { "kind": "simple", "value": "OK" }
    },
    {
      "name": "client_reply_on",
      "now_ms": 15,
      "argv": ["CLIENT", "REPLY", "ON"],
      "expect": { "kind": "simple", "value": "OK" }
    },
    {
      "name": "client_kill_returns_zero",
      "now_ms": 16,
      "argv": ["CLIENT", "KILL", "ID", "99999"],
      "expect": { "kind": "integer", "value": 0 }
    },
    {
      "name": "client_pause_ok",
      "now_ms": 17,
      "argv": ["CLIENT", "PAUSE", "1000"],
      "expect": { "kind": "simple", "value": "OK" }
    },
    {
      "name": "client_unpause_ok",
      "now_ms": 18,
      "argv": ["CLIENT", "UNPAUSE"],
      "expect": { "kind": "simple", "value": "OK" }
    },
    {
      "name": "client_tracking_on",
      "now_ms": 19,
      "argv": ["CLIENT", "TRACKING", "ON"],
      "expect": { "kind": "simple", "value": "OK" }
    },
    {
      "name": "client_caching_yes",
      "now_ms": 20,
      "argv": ["CLIENT", "CACHING", "YES"],
      "expect": { "kind": "simple", "value": "OK" }
    },
    {
      "name": "client_unknown_subcommand",
      "now_ms": 21,
      "argv": ["CLIENT", "BOGUS"],
      "expect": {
        "kind": "error",
        "value": "ERR Unknown subcommand or wrong number of arguments for CLIENT BOGUS"
      }
    },
    {
      "name": "client_wrong_arity_no_args",
      "now_ms": 22,
      "argv": ["CLIENT"],
      "expect": {
        "kind": "error",
        "value": "ERR wrong number of arguments for 'CLIENT' command"
      }
    },
    {
      "name": "client_pause_wrong_arity",
      "now_ms": 23,
      "argv": ["CLIENT", "PAUSE"],
      "expect": {
        "kind": "error",
        "value": "ERR wrong number of arguments for 'CLIENT' command"
      }
    },
    {
      "name": "client_tracking_wrong_arity",
      "now_ms": 24,
      "argv": ["CLIENT", "TRACKING"],
      "expect": {
        "kind": "error",
        "value": "ERR wrong number of arguments for 'CLIENT' command"
      }
    },

    {
      "name": "client_id_wrong_arity",
      "now_ms": 31,
      "argv": ["CLIENT", "ID", "extra"],
      "expect": {
        "kind": "error",
        "value": "ERR wrong number of arguments for 'CLIENT' command"
      }
    },

    {
      "name": "client_setname_for_list_test",
      "now_ms": 40,
      "argv": ["CLIENT", "SETNAME", "testconn"],
      "expect": { "kind": "simple", "value": "OK" }
    },
    {
      "name": "client_getname_after_list_setup",
      "now_ms": 41,
      "argv": ["CLIENT", "GETNAME"],
      "expect": { "kind": "bulk", "value": "testconn" }
    },

    {
      "name": "client_no_evict_wrong_arity",
      "now_ms": 50,
      "argv": ["CLIENT", "NO-EVICT"],
      "expect": {
        "kind": "error",
        "value": "ERR wrong number of arguments for 'CLIENT' command"
      }
    },
    {
      "name": "client_no_touch_wrong_arity",
      "now_ms": 51,
      "argv": ["CLIENT", "NO-TOUCH"],
      "expect": {
        "kind": "error",
        "value": "ERR wrong number of arguments for 'CLIENT' command"
      }
    },
    {
      "name": "client_no_touch_invalid_arg",
      "now_ms": 52,
      "argv": ["CLIENT", "NO-TOUCH", "MAYBE"],
      "expect": {
        "kind": "error",
        "value": "ERR argument must be 'on' or 'off'"
      }
    },
    {
      "name": "client_reply_wrong_arity",
      "now_ms": 53,
      "argv": ["CLIENT", "REPLY"],
      "expect": {
        "kind": "error",
        "value": "ERR wrong number of arguments for 'CLIENT' command"
      }
    },

    {
      "name": "client_unpause_wrong_arity",
      "now_ms": 60,
      "argv": ["CLIENT", "UNPAUSE", "extra"],
      "expect": {
        "kind": "error",
        "value": "ERR wrong number of arguments for 'CLIENT' command"
      }
    },
    {
      "name": "client_pause_invalid_timeout",
      "now_ms": 61,
      "argv": ["CLIENT", "PAUSE", "notanumber"],
      "expect": {
        "kind": "error",
        "value": "ERR value is not an integer or out of range"
      }
    },
    {
      "name": "client_pause_with_write",
      "now_ms": 62,
      "argv": ["CLIENT", "PAUSE", "1000", "WRITE"],
      "expect": { "kind": "simple", "value": "OK" }
    },
    {
      "name": "client_pause_with_all",
      "now_ms": 63,
      "argv": ["CLIENT", "PAUSE", "500", "ALL"],
      "expect": { "kind": "simple", "value": "OK" }
    },

    {
      "name": "client_caching_wrong_arity",
      "now_ms": 70,
      "argv": ["CLIENT", "CACHING"],
      "expect": {
        "kind": "error",
        "value": "ERR wrong number of arguments for 'CLIENT' command"
      }
    },
    {
      "name": "client_caching_no",
      "now_ms": 71,
      "argv": ["CLIENT", "CACHING", "NO"],
      "expect": { "kind": "simple", "value": "OK" }
    },

    {
      "name": "client_tracking_off",
      "now_ms": 80,
      "argv": ["CLIENT", "TRACKING", "OFF"],
      "expect": { "kind": "simple", "value": "OK" }
    },

    {
      "name": "client_kill_addr",
      "now_ms": 90,
      "argv": ["CLIENT", "KILL", "127.0.0.1:12345"],
      "expect": { "kind": "integer", "value": 0 }
    },

    {
      "name": "client_setname_clear_for_reset_test",
      "now_ms": 95,
      "argv": ["CLIENT", "SETNAME", "preresetname"],
      "expect": { "kind": "simple", "value": "OK" }
    },
    {
      "name": "client_getname_before_reset",
      "now_ms": 96,
      "argv": ["CLIENT", "GETNAME"],
      "expect": { "kind": "bulk", "value": "preresetname" }
    },
    {
      "name": "reset_clears_client_name",
      "now_ms": 97,
      "argv": ["RESET"],
      "expect": { "kind": "simple", "value": "RESET" }
    },
    {
      "name": "client_getname_after_reset",
      "now_ms": 98,
      "argv": ["CLIENT", "GETNAME"],
      "expect": { "kind": "bulk", "value": null }
    }
  ]
}
