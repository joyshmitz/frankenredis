{
  "suite": "core_module_sentinel",
  "cases": [
    {
      "name": "monitor_returns_ok",
      "now_ms": 0,
      "argv": ["MONITOR"],
      "expect": {
        "kind": "simple",
        "value": "OK"
      }
    },
    {
      "name": "monitor_wrong_arity",
      "now_ms": 1,
      "argv": ["MONITOR", "extra"],
      "expect": {
        "kind": "error",
        "value": "ERR wrong number of arguments for 'monitor' command"
      }
    },
    {
      "name": "module_wrong_arity",
      "now_ms": 10,
      "argv": ["MODULE"],
      "expect": {
        "kind": "error",
        "value": "ERR wrong number of arguments for 'module' command"
      }
    },
    {
      "name": "module_list_returns_empty",
      "now_ms": 11,
      "argv": ["MODULE", "LIST"],
      "expect": {
        "kind": "array",
        "value": []
      }
    },
    {
      "name": "module_help_returns_array",
      "now_ms": 12,
      "argv": ["MODULE", "HELP"],
      "expect": {
        "kind": "array",
        "value": [
          { "kind": "simple", "value": "MODULE <subcommand> [<arg> [value] [opt] ...]. Subcommands are:" },
          { "kind": "simple", "value": "LIST" },
          { "kind": "simple", "value": "    Return a list of loaded modules." },
          { "kind": "simple", "value": "LOAD <path> [<arg> ...]" },
          { "kind": "simple", "value": "    Load a module library from <path>, passing to it any optional arguments." },
          { "kind": "simple", "value": "LOADEX <path> [[CONFIG NAME VALUE] [CONFIG NAME VALUE]] [ARGS ...]" },
          { "kind": "simple", "value": "    Load a module library from <path>, while passing it module configurations and optional arguments." },
          { "kind": "simple", "value": "UNLOAD <name>" },
          { "kind": "simple", "value": "    Unload a module." },
          { "kind": "simple", "value": "HELP" },
          { "kind": "simple", "value": "    Print this help." }
        ]
      }
    },
    {
      "name": "module_load_errors",
      "now_ms": 13,
      "argv": ["MODULE", "LOAD", "/nonexistent/path"],
      "expect": {
        "kind": "error",
        "value": "ERR MODULE command not allowed. If the enable-module-command option is set to \"local\", you can run it from a local connection, otherwise you need to set this option in the configuration file, and then restart the server."
      }
    },
    {
      "name": "module_loadex_errors",
      "now_ms": 14,
      "argv": ["MODULE", "LOADEX", "/nonexistent/path"],
      "expect": {
        "kind": "error",
        "value": "ERR MODULE command not allowed. If the enable-module-command option is set to \"local\", you can run it from a local connection, otherwise you need to set this option in the configuration file, and then restart the server."
      }
    },
    {
      "name": "module_unload_not_found",
      "now_ms": 15,
      "argv": ["MODULE", "UNLOAD", "mymodule"],
      "expect": {
        "kind": "error",
        "value": "ERR MODULE command not allowed. If the enable-module-command option is set to \"local\", you can run it from a local connection, otherwise you need to set this option in the configuration file, and then restart the server."
      }
    },
    {
      "name": "module_unknown_subcommand",
      "now_ms": 16,
      "argv": ["MODULE", "BOGUS"],
      "expect": {
        "kind": "error",
        "value": "ERR unknown subcommand 'BOGUS'. Try MODULE HELP."
      }
    },
    {
      "name": "module_load_missing_path",
      "now_ms": 17,
      "argv": ["MODULE", "LOAD"],
      "expect": {
        "kind": "error",
        "value": "ERR wrong number of arguments for 'module|load' command"
      }
    },
