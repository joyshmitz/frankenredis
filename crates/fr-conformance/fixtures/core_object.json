      "argv": ["SET", "obj_int", "12345"],
      "expect": { "kind": "simple", "value": "OK" }
    },
    {
      "name": "object_encoding_returns_int",
      "now_ms": 1,
      "argv": ["OBJECT", "ENCODING", "obj_int"],
      "expect": { "kind": "bulk", "value": "int" }
    },
