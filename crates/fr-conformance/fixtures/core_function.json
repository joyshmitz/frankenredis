    {
      "name": "function_help",
      "now_ms": 0,
      "argv": [
        "FUNCTION",
        "HELP"
      ],
      "expect": {
        "kind": "array",
        "value": [
          {
            "kind": "simple",
            "value": "FUNCTION <subcommand> [<arg> [value] [opt] ...]. Subcommands are:"
          },
          {
            "kind": "simple",
            "value": "LOAD [REPLACE] <FUNCTION CODE>"
          },
          {
            "kind": "simple",
            "value": "    Create a new library with the given library name and code."
          },
          {
            "kind": "simple",
            "value": "DELETE <LIBRARY NAME>"
          },
          {
            "kind": "simple",
            "value": "    Delete the given library."
          },
          {
            "kind": "simple",
            "value": "LIST [LIBRARYNAME PATTERN] [WITHCODE]"
          },
          {
            "kind": "simple",
            "value": "    Return general information on all the libraries:"
          },
          {
            "kind": "simple",
            "value": "    * Library name"
          },
          {
            "kind": "simple",
            "value": "    * The engine used to run the Library"
          },
          {
            "kind": "simple",
            "value": "    * Library description"
          },
          {
            "kind": "simple",
            "value": "    * Functions list"
          },
          {
            "kind": "simple",
            "value": "    * Library code (if WITHCODE is given)"
          },
          {
            "kind": "simple",
            "value": "    It also possible to get only function that matches a pattern using LIBRARYNAME argument."
          },
          {
            "kind": "simple",
            "value": "STATS"
          },
          {
            "kind": "simple",
            "value": "    Return information about the current function running:"
          },
          {
            "kind": "simple",
            "value": "    * Function name"
          },
          {
            "kind": "simple",
            "value": "    * Command used to run the function"
          },
          {
            "kind": "simple",
            "value": "    * Duration in MS that the function is running"
          },
          {
            "kind": "simple",
            "value": "    If no function is running, return nil"
          },
          {
            "kind": "simple",
            "value": "    In addition, returns a list of available engines."
          },
          {
            "kind": "simple",
            "value": "KILL"
          },
          {
            "kind": "simple",
            "value": "    Kill the current running function."
          },
          {
            "kind": "simple",
            "value": "FLUSH [ASYNC|SYNC]"
          },
          {
            "kind": "simple",
            "value": "    Delete all the libraries."
          },
          {
            "kind": "simple",
            "value": "    When called without the optional mode argument, the behavior is determined by the"
          },
          {
            "kind": "simple",
            "value": "    lazyfree-lazy-user-flush configuration directive. Valid modes are:"
          },
          {
            "kind": "simple",
            "value": "    * ASYNC: Asynchronously flush the libraries."
          },
          {
            "kind": "simple",
            "value": "    * SYNC: Synchronously flush the libraries."
          },
          {
            "kind": "simple",
            "value": "DUMP"
          },
          {
            "kind": "simple",
            "value": "    Return a serialized payload representing the current libraries, can be restored using FUNCTION RESTORE command"
          },
          {
            "kind": "simple",
            "value": "RESTORE <PAYLOAD> [FLUSH|APPEND|REPLACE]"
          },
          {
            "kind": "simple",
            "value": "    Restore the libraries represented by the given payload, it is possible to give a restore policy to"
          },
          {
            "kind": "simple",
            "value": "    control how to handle existing libraries (default APPEND):"
          },
          {
            "kind": "simple",
            "value": "    * FLUSH: delete all existing libraries."
          },
          {
            "kind": "simple",
            "value": "    * APPEND: appends the restored libraries to the existing libraries. On collision, abort."
          },
          {
            "kind": "simple",
            "value": "    * REPLACE: appends the restored libraries to the existing libraries, On collision, replace the old"
          },
          {
            "kind": "simple",
            "value": "      libraries with the new libraries (notice that even on this option there is a chance of failure"
          },
          {
            "kind": "simple",
            "value": "      in case of functions name collision with another library)."
          },
          {
            "kind": "simple",
            "value": "HELP"
          },
          {
            "kind": "simple",
            "value": "    Print this help."
          }
        ]
      }
    },
