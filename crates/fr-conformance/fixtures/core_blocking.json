{
  "suite": "core_blocking",
  "cases": [
    {
      "name": "blocking_flush_setup",
      "now_ms": 0,
      "argv": [
        "FLUSHDB"
      ],
      "expect": {
        "kind": "simple",
        "value": "OK"
      }
    },
    {
      "name": "blpop_wrong_arity_no_args",
      "now_ms": 0,
      "argv": [
        "BLPOP"
      ],
      "expect": {
        "kind": "error",
        "value": "ERR wrong number of arguments for 'blpop' command"
      }
    },
    {
      "name": "blpop_wrong_arity_one_arg",
      "now_ms": 0,
      "argv": [
        "BLPOP",
        "key"
      ],
      "expect": {
        "kind": "error",
        "value": "ERR wrong number of arguments for 'blpop' command"
      }
    },
    {
      "name": "blpop_empty_key_returns_nil",
      "now_ms": 0,
      "argv": [
        "BLPOP",
        "nokey",
        "0"
      ],
      "expect": {
        "kind": "null_array",
        "value": null
      }
    },
    {
      "name": "blpop_negative_timeout",
      "now_ms": 0,
      "argv": [
        "BLPOP",
        "key",
        "-1"
      ],
      "expect": {
        "kind": "error",
        "value": "ERR timeout is negative"
      }
    },
    {
      "name": "blpop_invalid_timeout",
      "now_ms": 0,
      "argv": [
        "BLPOP",
        "key",
        "abc"
      ],
      "expect": {
        "kind": "error",
        "value": "ERR timeout is not a float or out of range"
      }
    },
    {
      "name": "blpop_float_timeout_ok",
      "now_ms": 0,
      "argv": [
        "BLPOP",
        "nokey",
        "1.5"
      ],
      "expect": {
        "kind": "null_array",
        "value": null
      }
    },
    {
      "name": "blpop_setup_data",
      "now_ms": 100,
      "argv": [
        "RPUSH",
        "blist1",
        "a",
        "b",
        "c"
      ],
      "expect": {
        "kind": "integer",
        "value": 3
      }
    },
    {
      "name": "blpop_with_data",
      "now_ms": 100,
      "argv": [
        "BLPOP",
        "blist1",
        "0"
      ],
      "expect": {
        "kind": "array",
        "value": [
          {
            "kind": "bulk",
            "value": "blist1"
          },
          {
            "kind": "bulk",
            "value": "a"
          }
        ]
      }
    },
    {
      "name": "blpop_multiple_keys_first_has_data",
      "now_ms": 100,
      "argv": [
        "BLPOP",
        "blist1",
        "nokey",
        "0"
      ],
      "expect": {
        "kind": "array",
        "value": [
          {
            "kind": "bulk",
            "value": "blist1"
          },
          {
            "kind": "bulk",
            "value": "b"
          }
        ]
      }
    },
    {
      "name": "blpop_multiple_keys_second_has_data",
      "now_ms": 100,
      "argv": [
        "BLPOP",
        "nokey",
        "blist1",
        "0"
      ],
      "expect": {
        "kind": "array",
        "value": [
          {
            "kind": "bulk",
            "value": "blist1"
          },
          {
            "kind": "bulk",
            "value": "c"
          }
        ]
      }
    },
    {
      "name": "blpop_multiple_keys_none_have_data",
      "now_ms": 100,
      "argv": [
        "BLPOP",
        "nokey1",
        "nokey2",
        "nokey3",
        "0"
      ],
      "expect": {
        "kind": "null_array",
        "value": null
      }
    },
    {
      "name": "blpop_wrongtype_setup",
      "now_ms": 100,
      "argv": [
        "SET",
        "bstr",
        "hello"
      ],
      "expect": {
        "kind": "simple",
        "value": "OK"
      }
    },
    {
      "name": "blpop_wrongtype",
      "now_ms": 100,
      "argv": [
        "BLPOP",
        "bstr",
        "0"
      ],
      "expect": {
        "kind": "error",
        "value": "WRONGTYPE Operation against a key holding the wrong kind of value"
      }
    },
    {
      "name": "blpop_case_insensitive",
      "now_ms": 100,
      "argv": [
        "blpop",
        "nokey",
        "0"
      ],
      "expect": {
        "kind": "null_array",
        "value": null
      }
    },
